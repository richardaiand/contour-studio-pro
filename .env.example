# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# Security
JWT_SECRET=change-me-to-a-long-random-string-min-64-chars-recommended
COOKIE_SECRET=change-me-to-another-long-random-string
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string-for-api-key-encryption

# Database (SQLite by default; use DATABASE_URL for Postgres on build.io)
DATABASE_URL=./data/contour-studio.db

# Geocoding (no key required for Nominatim; OpenCage optional)
NOMINATIM_USER_AGENT="contour-studio/0.1.0 (your-email@example.com)"
OPENCAGE_API_KEY=

# DEM / Elevation providers
OPEN_TOPOGRAPHY_API_KEY=
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# AI providers (per-user keys override this if set; these are app defaults)
AIAND_ENDPOINT=https://api.aiand.com/v1
AIAND_MODEL=deepseek-ai/deepseek-v4-pro
AIAND_API_KEY=

OPENAI_ENDPOINT=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_API_KEY=

ANTHROPIC_ENDPOINT=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_API_KEY=

OPENROUTER_ENDPOINT=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_API_KEY=

OLLAMA_ENDPOINT=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# Request timeout in ms (build.io setting)
REQUEST_TIMEOUT_MS=120000

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
